{
  "ingress": [
    {
      "name": "from_source",
      "socket": {
        "url": "sub+bind:ipc:///tmp/zmq-sockets/input-video.ipc"
      }
    }
  ],
  "egress": [
    {
      "name": "to_yolov8",
      "socket": {
        "url": "dealer+bind:ipc:///tmp/zmq-sockets/yolov8.ipc"
      },
      "matcher": "[yolov8]"
    },
    {
      "name": "to_peoplenet",
      "socket": {
        "url": "dealer+bind:ipc:///tmp/zmq-sockets/peoplenet.ipc"
      },
      "matcher": "[peoplenet]"
    }
  ],
  "common": {
    "handler": {
      "module": "router_handler",
      "class_name": "SourceIdRouter"
    }
  }
}